# ---------------------------------------------------------------------------
# Configuração do ambiente — Estratificação de Risco
# ---------------------------------------------------------------------------
# Na PRIMEIRA execução, o sistema abre um assistente de configuração no
# navegador (/setup) para você criar a conta de administrador. Não é preciso
# preencher usuário/senha aqui.
#
# SECRET_KEY é opcional: se ficar em branco, uma chave forte é gerada e
# guardada automaticamente em instance/secret_key na primeira execução.
# ---------------------------------------------------------------------------

# SECRET_KEY=defina_uma_chave_forte_para_fixar_a_sessao
DATABASE_URL=sqlite:///estratificacao_risco.db

# --- Instalação automatizada (opcional) ------------------------------------
# Para provisionar sem interação, defina AMBAS as variáveis abaixo. Nesse caso
# o admin é criado no primeiro boot e o assistente /setup não aparece.
# Deixe comentadas para usar o assistente gráfico (recomendado).
# ADMIN_USER=admin
# ADMIN_PASSWORD=defina_uma_senha_forte_aqui
